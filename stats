```{r}
# Clean batting average into numeric
stats <- stats %>%
  mutate(
    batting_avg = as.numeric(batting_avg),
    avg_swing_speed = as.numeric(avg_swing_speed)
  )

# Top 50 batters by bat speed
top_50_bat_speed <- stats %>%
  filter(!is.na(avg_swing_speed)) %>%
  arrange(desc(avg_swing_speed)) %>%
  select(
    `last_name, first_name`,
    player_id,
    year,
    ab,
    hit,
    home_run,
    batting_avg,
    avg_swing_speed
  ) %>%
  slice_head(n = 50)

# Top 50 batters by batting average
top_50_batting_avg <- stats %>%
  filter(!is.na(batting_avg)) %>%
  arrange(desc(batting_avg)) %>%
  select(
    `last_name, first_name`,
    player_id,
    year,
    ab,
    hit,
    home_run,
    batting_avg,
    avg_swing_speed
  ) %>%
  slice_head(n = 50)
# Print results
print(top_50_bat_speed)
print(top_50_batting_avg)
```
